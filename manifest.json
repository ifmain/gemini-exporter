{
  "manifest_version": 3,
  "name": "AI Chat Exporter (Gemini Only)",
  "description": "Export Gemini chats to Markdown, JSON, HTML with perfectly embedded images.",
  "version": "4.4.0",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["src/lib/turndown.js", "src/content_scripts/gemini.js"],
      "run_at": "document_idle"
    }
  ]
}